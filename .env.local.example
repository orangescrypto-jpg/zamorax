# ─────────────────────────────────────────────────────────────────
# ZAMORAX — Environment Variables (Supabase Auth Migration)
# Copy to .env.local and fill in all values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────

# ── Supabase (Auth) ───────────────────────────────────────────────
# Get from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# Service role key — SERVER ONLY, never expose to browser
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── Cloudflare D1 (Database) ─────────────────────────────────────
CF_ACCOUNT_ID=your_cloudflare_account_id
CF_D1_DATABASE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
CF_API_TOKEN=your_cloudflare_api_token_with_d1_edit_permission

# ── Cloudflare R2 (File Storage) ─────────────────────────────────
R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=zamorax-files
R2_PUBLIC_URL=https://files.yourdomain.com
NEXT_PUBLIC_R2_PUBLIC_URL=https://files.yourdomain.com
NEXT_PUBLIC_R2_HOSTNAME=files.yourdomain.com

# ── Email (Resend) ───────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Algolia (Search) ─────────────────────────────────────────────
NEXT_PUBLIC_ALGOLIA_APP_ID=
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=
ALGOLIA_ADMIN_KEY=

# ── Paystack (Payments) ──────────────────────────────────────────
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=

# ── App URL ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Sentry ────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=

# ── ZamoraxLogic ─────────────────────────────────────────────────
NEXT_PUBLIC_ZAMORAXLOGIC_URL=https://zamoraxlogic.com
ZAMORAXLOGIC_API_URL=https://zamoraxlogic.com/api/v1
ZAMORAXLOGIC_API_KEY=
ZAMORAXLOGIC_WEBHOOK_SECRET=
