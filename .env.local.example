# ─────────────────────────────────────────────────────────────────
# ZAMORAX — Environment Variables
# FIREBASE (Auth) + CLOUDFLARE D1 (Database) + R2 (Storage)
#
# Copy this file to .env.local and fill in all values.
# NEVER commit .env.local to git.
# All vars prefixed NEXT_PUBLIC_* are exposed to the browser.
# ─────────────────────────────────────────────────────────────────

# ── Firebase (Auth ONLY — all app data lives in D1) ──────────────
# Get from: Firebase Console → Project Settings → General → Your apps
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
# Firebase Admin SDK — Project Settings → Service Accounts → Generate new private key
# Paste the ENTIRE downloaded JSON file as a single-line string
FIREBASE_SERVICE_ACCOUNT=

# ── Cloudflare D1 (Database) ─────────────────────────────────────
# Get from: Cloudflare Dashboard → Workers & Pages → D1
CF_ACCOUNT_ID=your_cloudflare_account_id
CF_D1_DATABASE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
CF_API_TOKEN=your_cloudflare_api_token_with_d1_edit_permission

# ── Cloudflare R2 (File Storage) ─────────────────────────────────
# Get from: Cloudflare Dashboard → R2 → Manage R2 API tokens
R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=zamorax-files
# Public URL for your R2 bucket (set up Custom Domain in R2 dashboard)
R2_PUBLIC_URL=https://files.yourdomain.com
NEXT_PUBLIC_R2_PUBLIC_URL=https://files.yourdomain.com
# Hostname only (without https://) — used in next.config.js image domains
NEXT_PUBLIC_R2_HOSTNAME=files.yourdomain.com

# ── Email (Resend) ───────────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Algolia (Search) ─────────────────────────────────────────────
NEXT_PUBLIC_ALGOLIA_APP_ID=
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=
ALGOLIA_ADMIN_KEY=

# ── Paystack (Payments) ──────────────────────────────────────────
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=

# ── App URL ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Sentry (Error Monitoring) ─────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=

# ── ZamoraxLogic Integration ─────────────────────────────────────
NEXT_PUBLIC_ZAMORAXLOGIC_URL=https://zamoraxlogic.com
ZAMORAXLOGIC_API_URL=https://zamoraxlogic.com/api/v1
ZAMORAXLOGIC_API_KEY=
ZAMORAXLOGIC_WEBHOOK_SECRET=

# ── REMOVED — Firebase (no longer used) ──────────────────────────
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=
# NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
# FIREBASE_ADMIN_SDK_JSON=
# ADMIN_TRIGGER_SECRET=
