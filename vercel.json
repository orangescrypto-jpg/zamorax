{
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "redirects": [
    { "source": "/dashboard", "destination": "/dashboard/buyer", "permanent": true },
    { "source": "/admin", "destination": "/admin/listings", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false
}
